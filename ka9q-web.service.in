# systemd unit for G0ORX's web front end to my radio receiver
# Phil Karn, KA9Q, Feb 2024

[Unit]
Description=G0ORX web server
Requires=network-online.target

[Service]
Type=simple
User=radio
Group=radio
AmbientCapabilities=CAP_SYS_NICE
ReadWritePaths=/etc/fftw @statedir@
UMask=002
EnvironmentFile=/etc/radio/ka9q-web-status.conf
ExecStart=@sbindir@/ka9q-web -m $STATUS -p 8081
Restart=always
RestartSec=5
TimeoutStopSec=5

[Install]
WantedBy=multi-user.target
